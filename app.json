{
  "expo": {
    "name": "PocketBooth",
    "slug": "pocketbooth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Designer.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Designer.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF5EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.pocketbooth",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "PocketBooth needs camera access to take photobooth pictures.",
        "NSPhotoLibraryAddUsageDescription": "PocketBooth needs access to save your photo strip."
      }
    },
    "android": {
      "package": "com.yourname.pocketbooth",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FAF5EB",
        "foregroundImage": "./assets/Designer.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/Designer.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "PocketBooth needs camera access to take photobooth pictures."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "PocketBooth needs access to save your photo strip.",
          "savePhotosPermission": "PocketBooth needs permission to save your photo strip."
        }
      ],
      "expo-sharing"
    ]
  }
}
